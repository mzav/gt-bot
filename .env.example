# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the Railway persistent volume. Do not change unless you rename the volume.
DATABASE_URL=sqlite+aiosqlite:////data/gtbot.db

# ── Scheduling ────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Berlin

# Numeric Telegram channel ID for twice-monthly announcements (negative for channels)
ANNOUNCEMENTS_CHANNEL_ID=

# Comma-separated days of month to post announcements
ANNOUNCE_DAYS=1,15

# Time of day to post (24h HH:MM, in TIMEZONE)
ANNOUNCE_TIME=10:00

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Litestream (SQLite → Backblaze B2 backup) ─────────────────────────────────
# B2 bucket name (create a private bucket in the B2 console)
LITESTREAM_BUCKET=

# S3-compatible endpoint for your B2 region, e.g.:
#   s3.us-west-004.backblazeb2.com
# Find yours under B2 console → Buckets → Endpoint
LITESTREAM_ENDPOINT=

# B2 Application Key ID (scoped to the bucket above)
LITESTREAM_KEY_ID=

# B2 Application Key secret
LITESTREAM_SECRET=
